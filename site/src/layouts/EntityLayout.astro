---
import BaseLayout from './BaseLayout.astro';
import RelationshipLinks from '../components/RelationshipLinks.astro';
import StatusBadge from '../components/StatusBadge.astro';

const { entry, relatedEntities = [], relatedWorks = [] } = Astro.props;
const description = entry.data.summary ?? `PerfectBlu encyclopedia entry for ${entry.data.title}.`;
---

<BaseLayout title={`${entry.data.title} | PerfectBlu`} description={description} section="Encyclopedia">
  <article class="detail-page">
    <p class="eyebrow">{entry.data.entity_type}</p>
    <h1>{entry.data.title}</h1>

    <dl class="metadata">
      <div>
        <dt>Continuity</dt>
        <dd>{entry.data.continuity.join(', ')}</dd>
      </div>
      <div>
        <dt>Status</dt>
        <dd><StatusBadge status={entry.data.status} /></dd>
      </div>
      <div>
        <dt>Spoiler level</dt>
        <dd>{entry.data.spoiler_level}</dd>
      </div>
      <div>
        <dt>First appearance</dt>
        <dd>{entry.data.first_appearance ?? 'TBD'}</dd>
      </div>
    </dl>

    <div class="content-body">
      <slot />
    </div>

    <RelationshipLinks title="Related entities" items={relatedEntities} />
    <RelationshipLinks title="Related works" items={relatedWorks} />
  </article>
</BaseLayout>
