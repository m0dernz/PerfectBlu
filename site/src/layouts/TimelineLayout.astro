---
import BaseLayout from './BaseLayout.astro';
import RelationshipLinks from '../components/RelationshipLinks.astro';
import StatusBadge from '../components/StatusBadge.astro';

const { entry, participants = [], locations = [], relatedWorks = [] } = Astro.props;
const description = entry.data.summary ?? `PerfectBlu timeline entry for ${entry.data.title}.`;
---

<BaseLayout title={`${entry.data.title} | PerfectBlu`} description={description} section="Timeline">
  <article class="detail-page">
    <p class="eyebrow">Timeline entry</p>
    <h1>{entry.data.title}</h1>

    <dl class="metadata">
      <div>
        <dt>Sequence</dt>
        <dd>{entry.data.sequence ?? 'TBD'}</dd>
      </div>
      <div>
        <dt>Continuity</dt>
        <dd>{entry.data.continuity.join(', ')}</dd>
      </div>
      <div>
        <dt>Status</dt>
        <dd><StatusBadge status={entry.data.status} /></dd>
      </div>
      <div>
        <dt>Certainty</dt>
        <dd>{entry.data.certainty}</dd>
      </div>
    </dl>

    <div class="content-body">
      <slot />
    </div>

    <RelationshipLinks title="Participants" items={participants} />
    <RelationshipLinks title="Locations" items={locations} />
    <RelationshipLinks title="Related works" items={relatedWorks} />
  </article>
</BaseLayout>
