---
const {
  title = 'PerfectBlu',
  description = 'A lightweight, source-first knowledge base for the DUNE universe.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/" aria-label="PerfectBlu home">PerfectBlu</a>
      <nav aria-label="Primary navigation">
        <a href="/works/">Works</a>
        <a href="/encyclopedia/">Encyclopedia</a>
        <a href="/timeline/">Timeline</a>
        <a href="/sources/">Sources</a>
        <a href="/search/">Search</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <p>Source-first DUNE universe reference. Built static by default.</p>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: dark;
    --bg: #06101f;
    --bg-soft: #0b1d34;
    --panel: #102a47;
    --text: #e8f2ff;
    --muted: #9db7d6;
    --accent: #5fb7ff;
    --accent-deep: #2d72ad;
    --line: rgba(159, 200, 255, 0.2);
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    min-height: 100vh;
    background:
      radial-gradient(circle at top left, rgba(62, 157, 255, 0.2), transparent 34rem),
      linear-gradient(135deg, var(--bg), #02060c 70%);
    color: var(--text);
    line-height: 1.65;
  }

  a {
    color: var(--accent);
  }

  .site-header,
  .site-footer {
    width: min(72rem, calc(100% - 2rem));
    margin: 0 auto;
  }

  .site-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--line);
  }

  .brand {
    color: var(--text);
    font-size: 1.25rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-decoration: none;
    text-transform: uppercase;
  }

  nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
  }

  nav a {
    color: var(--muted);
    text-decoration: none;
  }

  nav a:hover {
    color: var(--text);
  }

  main {
    width: min(72rem, calc(100% - 2rem));
    margin: 0 auto;
    padding: 3rem 0;
  }

  .hero {
    display: grid;
    gap: 1.5rem;
    padding: clamp(2rem, 6vw, 5rem);
    border: 1px solid var(--line);
    border-radius: 1.5rem;
    background: rgba(16, 42, 71, 0.72);
    box-shadow: 0 2rem 6rem rgba(0, 0, 0, 0.25);
  }

  .eyebrow {
    margin: 0;
    color: var(--accent);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  h1 {
    max-width: 12ch;
    margin: 0;
    font-size: clamp(3rem, 10vw, 7rem);
    line-height: 0.95;
  }

  h2 {
    margin-top: 2.5rem;
  }

  .lede {
    max-width: 48rem;
    margin: 0;
    color: var(--muted);
    font-size: clamp(1.1rem, 2vw, 1.35rem);
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr));
    gap: 1rem;
    margin-top: 2rem;
  }

  .card {
    padding: 1.25rem;
    border: 1px solid var(--line);
    border-radius: 1rem;
    background: rgba(6, 16, 31, 0.72);
  }

  .card h3 {
    margin-top: 0;
  }

  .site-footer {
    padding: 2rem 0 3rem;
    color: var(--muted);
    border-top: 1px solid var(--line);
  }

  @media (max-width: 42rem) {
    .site-header {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>
