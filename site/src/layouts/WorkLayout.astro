---
import BaseLayout from './BaseLayout.astro';
import RelationshipLinks from '../components/RelationshipLinks.astro';
import StatusBadge from '../components/StatusBadge.astro';

const { work, introducedEntities = [] } = Astro.props;
const description = work.data.summary ?? `PerfectBlu source page for ${work.data.title}.`;
---

<BaseLayout title={`${work.data.title} | PerfectBlu`} description={description} section="Works">
  <article class="detail-page">
    <p class="eyebrow">{work.data.medium} | {work.data.publication_date ?? 'Date TBD'}</p>
    <h1>{work.data.title}</h1>

    <dl class="metadata">
      <div>
        <dt>Creators</dt>
        <dd>{work.data.creators.join(', ')}</dd>
      </div>
      <div>
        <dt>Continuity</dt>
        <dd>{work.data.continuity.join(', ')}</dd>
      </div>
      <div>
        <dt>Status</dt>
        <dd><StatusBadge status={work.data.status} /></dd>
      </div>
      <div>
        <dt>Spoiler level</dt>
        <dd>{work.data.spoiler_level}</dd>
      </div>
    </dl>

    <div class="content-body">
      <slot />
    </div>

    <RelationshipLinks title="Introduced entities" items={introducedEntities} />
  </article>
</BaseLayout>

<style is:global>
  .detail-page h1 {
    max-width: none;
  }

  .metadata {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(12rem, 1fr));
    gap: 1rem;
    margin: 2rem 0;
  }

  .metadata div {
    padding: 1rem;
    border: 1px solid var(--line);
    border-radius: 0.8rem;
    background: rgba(16, 42, 71, 0.55);
  }

  dt {
    color: var(--muted);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  dd {
    margin: 0.25rem 0 0;
  }

  .content-body {
    max-width: 48rem;
  }
</style>
