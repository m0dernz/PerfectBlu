---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const entries = (await getCollection('timeline')).sort((a, b) =>
  (a.data.sequence ?? 999999) - (b.data.sequence ?? 999999),
);
---

<BaseLayout title="Timeline | PerfectBlu" description="Timeline entries for the DUNE universe.">
  <section class="page-heading">
    <p class="eyebrow">Events and sequence</p>
    <h1>Timeline</h1>
    <p class="lede">Source-backed event pages organized in provisional narrative sequence.</p>
  </section>

  <section class="list-section" aria-labelledby="timeline-entries">
    <h2 id="timeline-entries">Timeline entries</h2>
    {
      entries.length > 0 ? (
        <div class="card-grid">
          {entries.map((entry) => (
            <article class="card">
              <p class="eyebrow">Sequence {entry.data.sequence ?? 'TBD'}</p>
              <h3><a href={`/timeline/${entry.data.slug}/`}>{entry.data.title}</a></h3>
              <p>{entry.data.summary}</p>
              <p class="meta">Certainty: {entry.data.certainty} | Status: {entry.data.status}</p>
            </article>
          ))}
        </div>
      ) : (
        <p>No timeline entries have been added yet.</p>
      )
    }
  </section>
</BaseLayout>

<style>
  .page-heading h1 {
    max-width: none;
  }

  .meta {
    color: var(--muted);
    font-size: 0.92rem;
  }
</style>
