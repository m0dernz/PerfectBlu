---
import EntityLayout from '../../layouts/EntityLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('encyclopedia');
  const works = await getCollection('works');
  const basePath = import.meta.env.BASE_URL.replace(/\/?$/, '/');
  const entityMap = new Map(entries.map((entry) => [entry.data.slug, entry]));
  const workMap = new Map(works.map((work) => [work.data.slug, work]));
  const entityLink = (slug: string) => {
    const entity = entityMap.get(slug);
    return entity
      ? { label: entity.data.title, href: `${basePath}encyclopedia/${entity.data.slug}/` }
      : { label: slug };
  };
  const workLink = (slug: string) => {
    const work = workMap.get(slug);
    return work
      ? { label: work.data.title, href: `${basePath}works/${work.data.slug}/` }
      : { label: slug };
  };

  return entries.map((entry) => ({
    params: { slug: entry.data.slug },
    props: {
      entry,
      relatedEntities: entry.data.related_entities.map((slug) => entityLink(slug)),
      relatedWorks: entry.data.related_works.map((slug) => workLink(slug)),
    },
  }));
}

const { entry, relatedEntities, relatedWorks } = Astro.props;
const { Content } = await render(entry);
---

<EntityLayout entry={entry} relatedEntities={relatedEntities} relatedWorks={relatedWorks}>
  <Content />
</EntityLayout>
