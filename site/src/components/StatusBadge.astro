---
type ContentStatus = 'stub' | 'draft' | 'reviewed' | 'canonical' | 'disputed';

const { status } = Astro.props as { status: ContentStatus };
const labels: Record<ContentStatus, string> = {
  stub: 'Stub',
  draft: 'Draft',
  reviewed: 'Reviewed',
  canonical: 'Canonical',
  disputed: 'Disputed',
};
const label = labels[status] ?? status;
---

<span class={`status-badge status-badge--${status}`} aria-label={`Content status: ${label}`} data-pagefind-filter="status">
  {label}
</span>

<style>
  .status-badge {
    display: inline-flex;
    align-items: center;
    width: fit-content;
    padding: 0.2rem 0.55rem;
    border: 1px solid var(--line);
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .status-badge--stub {
    background: rgba(157, 183, 214, 0.12);
    color: var(--muted);
  }

  .status-badge--draft {
    background: rgba(95, 183, 255, 0.14);
    color: var(--accent);
  }

  .status-badge--reviewed,
  .status-badge--canonical {
    background: rgba(93, 214, 146, 0.14);
    color: #8ff0bd;
  }

  .status-badge--disputed {
    background: rgba(255, 194, 102, 0.14);
    color: #ffd18a;
  }
</style>
